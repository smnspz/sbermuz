---
import { PhotoColumn } from '../molecules';
import { getPhotoDate } from '../../lib/datetime';
import type { Locale } from '../../lib/i18n';

interface Props {
  title: string;
  date: string;
  dateEn: string;
  rawDate: string;
  flyer: string;
  flyerWidth: number;
  flyerHeight: number;
  photos?: { src: string; width: number; height: number }[];
  year: string;
  locale?: Locale;
}

const { title, date, dateEn, rawDate, flyer, flyerWidth, flyerHeight, photos, year, locale = 'it' } = Astro.props;
const displayDate = locale === 'en' ? dateEn : date;

const FLYER_WIDTH = 500;
const flyerSizedHeight = Math.round(flyerHeight * FLYER_WIDTH / flyerWidth);
const flyerSrc = `${flyer}?width=${FLYER_WIDTH}&format=webp&quality=40&withoutEnlargement=true`;

const PHOTO_WIDTH = 400;

interface PhotoItem {
  src: string;
  originalSrc: string;
  id: string;
  width: number;
  height: number;
}

// Split pictures in two columns
const leftPhotos: PhotoItem[] = [];
const rightPhotos: PhotoItem[] = [];

if (photos) {
  photos.forEach((p, i) => {
    const sizedHeight = Math.round(p.height * PHOTO_WIDTH / p.width);
    const item = { src: `${p.src}?width=${PHOTO_WIDTH}&format=webp&quality=40&withoutEnlargement=true`, originalSrc: p.src, id: String(i + 1), width: PHOTO_WIDTH, height: sizedHeight };
    if (i % 2 === 0) leftPhotos.push(item);
    else rightPhotos.push(item);
  });
}

const allPhotos = photos ? photos.map((p, i) => {
  const sizedHeight = Math.round(p.height * PHOTO_WIDTH / p.width);
  return { src: `${p.src}?width=${PHOTO_WIDTH}&format=webp&quality=40&withoutEnlargement=true`, originalSrc: p.src, id: String(i + 1), width: PHOTO_WIDTH, height: sizedHeight };
}) : [];
const hasPhotos = photos && photos.length > 0;
const photoDate = hasPhotos ? getPhotoDate(rawDate) : '';
---

{hasPhotos ? (
  <section data-year={year} class="grid grid-cols-1 md:grid-cols-[1fr_1.2fr_1fr] gap-12 px-6 pb-8 pt-12 md:pb-12 md:pt-28 max-w-6xl mx-auto">
    <PhotoColumn photos={leftPhotos} date={photoDate} class="hidden md:flex flex-col gap-40" />

    <div class="md:sticky md:top-[calc(var(--header-bottom)+1rem)] md:self-start text-center">
      <h2 class="text-3xl font-bold font-display mt-8">{title}</h2>
      <p class="text-sm opacity-60 mt-1 mb-6">{displayDate}</p>
      <img src={flyerSrc} alt="" width={FLYER_WIDTH} height={flyerSizedHeight} class="w-full block rounded-lg cursor-pointer" data-flyer-src={flyer} />
    </div>

    <PhotoColumn photos={rightPhotos} date={photoDate} class="hidden md:flex flex-col gap-40 mt-12" />

    <!-- Mobile: photos below flyer -->
    <PhotoColumn photos={allPhotos} date={photoDate} class="flex flex-col gap-8 md:hidden" />
  </section>
) : (
  <section data-year={year} class="relative grid grid-cols-1 md:grid-cols-2 gap-12 px-6 py-12 md:min-h-[calc(100vh-5rem)] md:pb-20 max-w-5xl mx-auto items-center">
    <div class="flex justify-center">
      <img src={flyerSrc} alt="" width={FLYER_WIDTH} height={flyerSizedHeight} class="w-full max-w-sm block rounded-lg cursor-pointer" data-flyer-src={flyer} />
    </div>
    <div class="flex flex-col gap-4">
      <h2 class="text-3xl font-bold font-display">{title}</h2>
      <p class="text-sm opacity-60">{displayDate}</p>
    </div>
  </section>
)}
