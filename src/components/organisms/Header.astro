---
import { Logo } from '../atoms';
---

<!-- Top fade gradient -->
<div class="hidden md:block fixed top-0 left-0 right-0 h-20 bg-linear-to-b from-white/60 to-transparent z-30 pointer-events-none"></div>

<header class="flex items-center justify-between px-6 py-5 mb-6 w-full gap-12 bg-white/80 backdrop-blur-md md:bg-white md:border-2 md:border-black md:shadow-[4px_4px_0_0_black] sticky top-0 z-40 md:px-12 md:mt-4 md:mx-auto md:max-w-2xl md:rounded-full md:top-4">
	<a href="/">
		<Logo />
	</a>

	<!-- TODO: Links will be dynamically fetched by cms? -->

	<!-- Desktop nav -->
	<nav class="hidden md:flex gap-6 text-base">
		<a href="/#chi-siamo" class="hover:underline underline-offset-4">chi siamo</a>
		<a href="/#gallery" class="hover:underline underline-offset-4">archivio</a>
		<a href="https://collettivosbermuz.bandcamp.com/" target="_blank" rel="noopener noreferrer" class="hover:underline underline-offset-4">ascolta</a>
	</nav>

	<!-- Mobile hamburger button -->
	<button id="menu-open" class="md:hidden" aria-label="Open menu">
		<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<line x1="3" y1="6" x2="21" y2="6" />
			<line x1="3" y1="12" x2="21" y2="12" />
			<line x1="3" y1="18" x2="21" y2="18" />
		</svg>
	</button>
</header>

<!-- Mobile overlay menu -->
<div id="mobile-menu" class="fixed inset-0 bg-bg z-50 flex-col items-center justify-center gap-8 text-2xl opacity-0 pointer-events-none transition-opacity duration-200">
	<button id="menu-close" class="absolute top-4 right-6" aria-label="Close menu">
		<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<line x1="18" y1="6" x2="6" y2="18" />
			<line x1="6" y1="6" x2="18" y2="18" />
		</svg>
	</button>
	<a href="/#chi-siamo" class="hover:underline underline-offset-4 mobile-menu-link">chi siamo</a>
	<a href="/#gallery" class="hover:underline underline-offset-4 mobile-menu-link">archivio</a>
	<a href="https://collettivosbermuz.bandcamp.com/" target="_blank" rel="noopener noreferrer" class="hover:underline underline-offset-4">ascolta</a>
	<a href="https://www.instagram.com/collettivo_sbermuz/" target="_blank" rel="noopener noreferrer" class="absolute bottom-8" aria-label="Instagram">
		<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
	</a>
</div>

<script>
	// Expose the header's bottom edge as a CSS variable so other components
	// (Hero height, EventCarousel sticky offset) can position relative to it
	const header = document.querySelector('header');
	if (header) {
		const update = () => {
			// distance from viewport top to header bottom
			const bottom = header.getBoundingClientRect().bottom; 
			document.documentElement.style.setProperty('--header-bottom', `${bottom}px`);
		};
		// set on load
		update(); 
		// recalculate on resize
		window.addEventListener('resize', update); 
	}

	const openBtn = document.getElementById('menu-open');
	const closeBtn = document.getElementById('menu-close');
	const menu = document.getElementById('mobile-menu');

	openBtn?.addEventListener('click', () => {
		menu?.classList.add('flex', 'opacity-100', 'pointer-events-auto');
		menu?.classList.remove('opacity-0', 'pointer-events-none');
	});

	const closeMenu = () => {
		menu?.classList.add('opacity-0', 'pointer-events-none');
		menu?.classList.remove('opacity-100', 'pointer-events-auto');
	};

	closeBtn?.addEventListener('click', closeMenu);

	// Close mobile menu when clicking in-page links
	menu?.querySelectorAll('.mobile-menu-link').forEach((link) => {
		link.addEventListener('click', closeMenu);
	});
</script>
