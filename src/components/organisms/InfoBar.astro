---
import { t, type Locale } from '../../lib/i18n';

interface Props {
	locale?: Locale;
}

const { locale = 'it' } = Astro.props;
---

<section id="chi-siamo" class="hero-fade border-y-4 border-black py-10 px-6 bg-black text-white md:bg-transparent md:text-black" style="--delay: 380ms">
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 ">
    <!-- About -->
    <div class="hero-fade" style="--delay: 400ms">
      <h3 class="text-2xl font-bold font-display mb-3">{t('info.aboutTitle', locale)}</h3>
      <p class="text-base leading-relaxed">{t('info.aboutText', locale)}</p>
    </div>

    <!-- Band -->
    <div class="hero-fade" style="--delay: 480ms">
      <h3 class="text-2xl font-bold font-display mb-3">{t('info.bandTitle', locale)}</h3>
      <p class="text-base leading-relaxed mb-4">{t('info.bandText', locale)}</p>
      <!-- Mobile: brutalist button -->
      <a href="mailto:collettivosbermuz@gmail.com" class="md:hidden w-full justify-center inline-flex items-center gap-2 px-6 py-3 text-base font-bold bg-white text-black border-2 border-white shadow-[4px_4px_0_0_rgba(255,255,255,0.3)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        {t('info.writeUs', locale)}
      </a>
      <!-- Desktop: text link -->
      <a href="mailto:collettivosbermuz@gmail.com" class="hidden md:inline-flex text-base items-center gap-1">
        <span class="underline underline-offset-4">collettivosbermuz@gmail.com</span> <span aria-hidden="true">&rarr;</span>
      </a>
    </div>

    <!-- Listen -->
    <div class="hero-fade" style="--delay: 560ms">
      <h3 class="text-2xl font-bold font-display mb-3">{t('info.listenTitle', locale)}</h3>
      <p class="text-base leading-relaxed mb-4">{t('info.listenText', locale)}</p>
      <!-- Mobile: brutalist button -->
      <a href="https://collettivosbermuz.bandcamp.com/" target="_blank" rel="noopener noreferrer" class="md:hidden w-full justify-center inline-flex items-center gap-2 px-6 py-3 text-base font-bold bg-white text-black border-2 border-white shadow-[4px_4px_0_0_rgba(255,255,255,0.3)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M0 18.75l7.437-13.5H24l-7.438 13.5z"/></svg>
        Bandcamp
      </a>
      <!-- Desktop: text link -->
      <a href="https://collettivosbermuz.bandcamp.com/" target="_blank" rel="noopener noreferrer" class="hidden md:inline-flex text-base items-center gap-1">
        <span class="underline underline-offset-4">Bandcamp</span> <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</section>
