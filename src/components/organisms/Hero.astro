---
interface Props {
  title: string;
  description: string;
  image: string;
  date: string;
  rawDate: string;
  address?: string;
  price?: string;
  eventSlug?: string;
}

import { Button, Marquee } from '../atoms';
import { generateIcs } from '../../lib/calendar';

const { title, description, image, date, rawDate, address, price, eventSlug } = Astro.props;

const icsContent = generateIcs({ title, description, date: rawDate, address });
---

<section class="min-h-[calc(100vh-var(--header-bottom,5rem))] md:h-[calc(100vh-var(--header-bottom,5rem))] flex flex-col px-6 pb-16 md:pb-0 max-w-6xl mx-auto">
  <div class="flex-1 flex items-center">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center w-full">
      <div class="flex justify-center hero-fade" style="--delay: 0ms">
        <img src={image} alt="" class="w-full max-w-md block rounded-lg" />
      </div>
      <div class="flex flex-col gap-4">
        <!-- Badge -->
        <span class="inline-block self-start px-4 py-1.5 text-xs font-bold uppercase tracking-wide bg-black text-white rounded-full hero-fade" style="--delay: 80ms">
          Prossimo evento
        </span>

        <!-- Title -->
        <h2 class="text-4xl md:text-5xl font-bold font-display hero-fade" style="--delay: 160ms">{title}</h2>

        <!-- Info rows -->
        <div class="flex flex-col gap-2 mt-1 hero-fade" style="--delay: 240ms">
          <!-- Date -->
          <div class="flex items-center gap-3 opacity-60">
            <svg class="w-5 h-5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            <span class="text-base">{date}</span>
          </div>

          <!-- Address -->
          {address && (
            <div class="flex items-center gap-3 opacity-60">
              <svg class="w-5 h-5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="10" r="3" /><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z" />
              </svg>
              <span class="text-base">{address}</span>
            </div>
          )}

          <!-- Price -->
          <div class="flex items-center gap-3 opacity-60">
            <svg class="w-5 h-5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="4" width="22" height="16" rx="2" ry="2" /><line x1="1" y1="10" x2="23" y2="10" />
            </svg>
            <span class="text-base">{price ?? 'Ingresso gratuito'}</span>
          </div>
        </div>

        <!-- Buttons -->
        <div class="flex flex-col md:flex-row gap-3 mt-3 hero-fade" style="--delay: 320ms">
          {eventSlug && (
            <Button href={`/event/${eventSlug}`} class="w-full md:w-auto justify-center">Dettagli evento</Button>
          )}
          <Button id="add-to-calendar" class="w-full md:w-auto justify-center" data-ics={icsContent}>
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /><line x1="12" y1="14" x2="12" y2="18" /><line x1="10" y1="16" x2="14" y2="16" />
            </svg>
            Aggiungi al calendario
          </Button>
        </div>
      </div>
    </div>
  </div>
  <a href="#gallery" id="scroll-hint" class="hidden md:flex flex-col items-center gap-4 pb-10 hover:opacity-80 transition-opacity duration-300 cursor-pointer no-underline shrink-0 hero-fade" style="--delay: 400ms; --end-opacity: 0.5">
    <p class="text-sm">scrolla per le foto degli eventi passati</p>
    <svg class="w-7 h-7 animate-bounce" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9" />
    </svg>
  </a>
</section>

<Marquee text="foto eventi passati" class="md:hidden mt-8" />

<style>
  @keyframes hero-drop {
    from {
      opacity: 0;
      transform: translateY(-12px);
    }
    to {
      opacity: var(--end-opacity, 1);
      transform: translateY(0);
    }
  }

  .hero-fade {
    opacity: 0;
    animation: hero-drop 0.4s ease-out forwards;
    animation-delay: var(--delay, 0ms);
  }
</style>

<script>
  const hint = document.getElementById('scroll-hint');
  if (hint) {
    window.addEventListener('scroll', () => {
      hint.style.opacity = String(Math.max(0, 0.5 - window.scrollY / 800));
    });
  }

  const calBtn = document.getElementById('add-to-calendar');
  calBtn?.addEventListener('click', () => {
    const ics = calBtn.dataset.ics;
    if (!ics) return;
    const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'evento.ics';
    a.click();
    URL.revokeObjectURL(url);
  });
</script>
