---
import { t, type Locale } from '../../lib/i18n';

interface Props {
  title: string;
  description: string;
  image: string;
  imageWidth: number;
  imageHeight: number;
  date: string;
  dateEn: string;
  rawDate: string;
  address?: string;
  price?: string;
  eventSlug?: string;
  locale?: Locale;
}

import { Button } from '../atoms';
import { generateIcs } from '../../lib/calendar';

const { title, description, image, imageWidth, imageHeight, date, dateEn, rawDate, address, price, eventSlug, locale = 'it' } = Astro.props;

const HERO_WIDTH = 700;
const heroHeight = Math.round(imageHeight * HERO_WIDTH / imageWidth);
const heroSrc = `${image}?width=${HERO_WIDTH}&format=webp&withoutEnlargement=true`;

const icsContent = generateIcs({ title, description, date: rawDate, address });
const displayDate = locale === 'en' ? dateEn : date;
const eventHref = locale === 'en' ? `/en/event/${eventSlug}` : `/event/${eventSlug}`;
---

<section class="flex flex-col px-6 pb-16 md:pb-24 md:pt-16 max-w-6xl mx-auto">
  <div class="flex-1 flex items-center">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center w-full">
      <div class="flex justify-center hero-fade" style="--delay: 0ms">
        <img src={heroSrc} alt="" width={HERO_WIDTH} height={heroHeight} class="w-full max-w-75 md:max-w-82.5 block rounded-lg" />
      </div>
      <div class="flex flex-col gap-4">
        <!-- Badge -->
        <span class="inline-block self-start px-4 py-1.5 text-xs font-bold uppercase tracking-wide bg-black text-white rounded-full hero-fade" style="--delay: 80ms">
          {t('hero.badge', locale)}
        </span>

        <!-- Title -->
        <h2 class="text-4xl md:text-5xl font-bold font-display hero-fade" style="--delay: 160ms">{title}</h2>

        <!-- Info rows -->
        <div class="flex flex-col gap-2 mt-1 hero-fade" style="--delay: 240ms">
          <!-- Date -->
          <div class="flex items-center gap-3 opacity-60">
            <svg class="w-5 h-5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            <span class="text-base">{displayDate}</span>
          </div>

          <!-- Address -->
          {address && (
            <div class="flex items-center gap-3 opacity-60">
              <svg class="w-5 h-5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="10" r="3" /><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z" />
              </svg>
              <span class="text-base">{address}</span>
            </div>
          )}

          <!-- Price -->
          <div class="flex items-center gap-3 opacity-60">
            <svg class="w-5 h-5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="4" width="22" height="16" rx="2" ry="2" /><line x1="1" y1="10" x2="23" y2="10" />
            </svg>
            <span class="text-base">{price ?? t('hero.freeEntry', locale)}</span>
          </div>
        </div>

        <!-- Buttons -->
        <div class="flex flex-col md:flex-row gap-3 mt-3 hero-fade" style="--delay: 320ms">
          {eventSlug && (
            <Button href={eventHref} class="w-full md:w-auto justify-center">{t('hero.details', locale)}</Button>
          )}
          <Button id="add-to-calendar" class="w-full md:w-auto justify-center" data-ics={icsContent}>
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /><line x1="12" y1="14" x2="12" y2="18" /><line x1="10" y1="16" x2="14" y2="16" />
            </svg>
            {t('hero.addCalendar', locale)}
          </Button>
        </div>
      </div>
    </div>
  </div>

</section>



<script>
  const calBtn = document.getElementById('add-to-calendar');
  calBtn?.addEventListener('click', () => {
    const ics = calBtn.dataset.ics;
    if (!ics) return;
    const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'evento.ics';
    a.click();
    URL.revokeObjectURL(url);
  });
</script>
