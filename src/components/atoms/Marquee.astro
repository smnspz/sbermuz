---
interface Props {
  text: string;
  class?: string;
}

const { text, class: className } = Astro.props;
const items = Array.from({ length: 10 });
---

<div class:list={["w-full overflow-hidden border-y-2 border-black py-3 bg-black text-white", className]}>
  <div class="marquee-track flex whitespace-nowrap gap-8 text-sm font-bold uppercase">
    {items.map(() => (
      <><span>{text}</span><span>&middot;</span></>
    ))}
  </div>
</div>

<style>
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .marquee-track {
    animation: marquee-scroll 12s linear infinite;
  }
</style>
