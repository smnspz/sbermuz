<button
  id="back-to-top"
  aria-label="Back to top"
  class="fixed right-6 bottom-6 z-40 opacity-0 pointer-events-none px-3 py-3 bg-white border-2 border-black font-bold shadow-[4px_4px_0_0_black] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all dark:bg-white dark:text-black dark:border-black dark:shadow-[4px_4px_0_0_rgba(0,0,0,0.3)]"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="square" stroke-linejoin="miter">
    <polyline points="18 15 12 9 6 15"></polyline>
  </svg>
</button>

<script>
  const btn = document.getElementById('back-to-top');
  const gallery = document.getElementById('gallery');
  if (btn && gallery) {
    let visible = false;

    function toggle(show: boolean) {
      if (show === visible) return;
      visible = show;
      if (show) {
        btn!.classList.remove('opacity-0', 'pointer-events-none');
        btn!.classList.add('opacity-100', 'pointer-events-auto');
      } else {
        btn!.classList.add('opacity-0', 'pointer-events-none');
        btn!.classList.remove('opacity-100', 'pointer-events-auto');
      }
    }

    function check() {
      const galleryTop = gallery!.getBoundingClientRect().top;
      // Show after scrolling ~200px into the gallery section
      toggle(galleryTop <= -200);
    }

    window.addEventListener('scroll', check, { passive: true });
    check();

    btn.addEventListener('click', () => {
      gallery!.scrollIntoView({ behavior: 'smooth' });
    });
  }
</script>
