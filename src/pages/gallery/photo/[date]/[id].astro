---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getEvents } from '../../../../lib/events';
import { getPhotoDate } from '../../../../lib/datetime';
import { t } from '../../../../lib/i18n';

const locale = 'it' as const;

export async function getStaticPaths() {
  const events = await getEvents();
  const paths: { params: { date: string; id: string }; props: { src: string; width: number; height: number; allPhotos: { src: string; date: string; id: string }[] } }[] = [];

  for (const event of events) {
    if (!event.photos) continue;
    const photoDate = getPhotoDate(event.rawDate);
    const eventPhotos = event.photos.map((p, i) => ({
      src: p.src,
      date: photoDate,
      id: String(i + 1),
    }));
    for (let j = 0; j < eventPhotos.length; j++) {
      const photo = eventPhotos[j];
      const p = event.photos![j];
      paths.push({
        params: { date: photo.date, id: photo.id },
        props: { src: photo.src, width: p.width, height: p.height, allPhotos: eventPhotos },
      });
    }
  }

  return paths;
}

const { src, width, height, allPhotos } = Astro.props;
const { date, id } = Astro.params;

const currentIndex = allPhotos.findIndex((p: { id: string }) => p.id === id);
const prev = currentIndex > 0 ? allPhotos[currentIndex - 1] : null;
const next = currentIndex < allPhotos.length - 1 ? allPhotos[currentIndex + 1] : null;
---

<BaseLayout locale={locale} title={`Photo ${id} - Sbermuz`} bodyClass="bg-black m-0 h-dvh flex flex-col overflow-hidden">
    <!-- Top bar -->
    <div class="flex items-center justify-center md:justify-between px-4 py-3 shrink-0">
      <a href="/" class="text-white/70 hover:text-white text-sm">&larr; {t('photo.back', locale)}</a>
      <span class="text-white/50 text-sm hidden md:inline">{currentIndex + 1} / {allPhotos.length}</span>
    </div>

    <!-- Image -->
    <div class="flex-1 flex items-center justify-center px-4 md:px-12 md:gap-8 min-h-0 overflow-hidden">
      {prev ? (
        <a href={`/gallery/photo/${prev.date}/${prev.id}`} class="hidden md:block text-white/50 hover:text-white text-4xl shrink-0">&lsaquo;</a>
      ) : (
        <span class="hidden md:block text-4xl invisible shrink-0">&lsaquo;</span>
      )}

      <img src={src} alt="" width={width} height={height} class="max-h-[calc(100dvh-7rem)] md:max-h-[calc(100dvh-4rem)] max-w-full object-contain" />

      {next ? (
        <a href={`/gallery/photo/${next.date}/${next.id}`} class="hidden md:block text-white/50 hover:text-white text-4xl shrink-0">&rsaquo;</a>
      ) : (
        <span class="hidden md:block text-4xl invisible shrink-0">&rsaquo;</span>
      )}
    </div>

    <!-- Mobile bottom nav -->
    <div class="flex md:hidden items-center justify-between px-6 py-3 shrink-0">
      {prev ? (
        <a href={`/gallery/photo/${prev.date}/${prev.id}`} class="text-white/50 hover:text-white text-2xl">&lsaquo;</a>
      ) : (
        <span class="text-2xl invisible">&lsaquo;</span>
      )}
      <span class="text-white/50 text-sm">{currentIndex + 1} / {allPhotos.length}</span>
      {next ? (
        <a href={`/gallery/photo/${next.date}/${next.id}`} class="text-white/50 hover:text-white text-2xl">&rsaquo;</a>
      ) : (
        <span class="text-2xl invisible">&rsaquo;</span>
      )}
    </div>

    <script is:inline define:vars={{ prev, next }}>
      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft' && prev) {
          window.location.href = `/gallery/photo/${prev.date}/${prev.id}`;
        }
        if (e.key === 'ArrowRight' && next) {
          window.location.href = `/gallery/photo/${next.date}/${next.id}`;
        }
        if (e.key === 'Escape') {
          window.location.href = '/';
        }
      });
    </script>
</BaseLayout>
