---
import { Header, Hero, InfoBar, EventCarousel, Footer, Lightbox } from '../components';
import { Button } from '../components/atoms';
import { getEvents } from '../lib/events';
import { getHero } from '../lib/hero';
import '../styles/global.css';

const [hero, events] = await Promise.all([getHero(), getEvents()]);
const years = [...new Set(events.map((e) => e.rawDate.slice(0, 4)))].sort().reverse();
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@400;700&family=Unbounded:wght@400;700&display=swap" rel="stylesheet" />
		<title>Collettivo Sbermuz</title>
	</head>
	<body class="bg-bg">
		<Header />
		<main>
			<Hero title={hero.title} description={hero.description} image={hero.image} date={hero.date} rawDate={hero.rawDate} address={hero.address} price={hero.price} eventSlug={hero.slug} />
			<!-- Desktop: full info bar -->
			<div class="hidden md:block">
				<InfoBar />
			</div>

			<!-- Mobile: "Sei una band?" before gallery -->
			<section class="md:hidden bg-black text-white py-12 px-6">
				<div class="max-w-6xl mx-auto">
					<h3 class="text-xs font-bold uppercase tracking-wide opacity-50 mb-3">Sei una band?</h3>
					<p class="text-2xl font-bold font-display mb-6">Vuoi suonare a Genova con noi?</p>
					<Button href="mailto:collettivosbermuz@gmail.com" class="w-full justify-center bg-white text-black border-white shadow-[4px_4px_0_0_rgba(255,255,255,0.3)]">Scrivici per suonare</Button>
				</div>
			</section>

			<div id="gallery"></div>
			<h2 class="text-4xl md:text-5xl font-bold font-display text-center pt-16 pb-2">Archivio eventi</h2>
			<nav class="flex flex-wrap gap-3 justify-center px-6 pt-4 pb-4 max-w-6xl mx-auto" aria-label="Filtra per anno">
				<button data-filter="all" class="gallery-filter border-2 border-black px-4 py-1 font-bold font-display shadow-[3px_3px_0_black] bg-black text-white">Tutti</button>
				{years.map((y) => (
					<button data-filter={y} class="gallery-filter border-2 border-black px-4 py-1 font-bold font-display shadow-[3px_3px_0_black] bg-white text-black">{y}</button>
				))}
			</nav>
			{events.map((event) => (
				<EventCarousel title={event.title} date={event.date} rawDate={event.rawDate} flyer={event.flyer} photos={event.photos} year={event.rawDate.slice(0, 4)} />
			))}
			<!-- Mobile: "Chi siamo" + "Newsletter" after gallery -->
			<section class="md:hidden border-t-4 border-black py-10 px-6">
				<div class="max-w-6xl mx-auto grid grid-cols-1 gap-8">
					<div>
						<h3 class="text-xs font-bold uppercase tracking-wide opacity-50 mb-3">Chi siamo</h3>
						<p class="text-base leading-relaxed">Collettivo musicale genovese. Organizziamo concerti dal 20XX.</p>
					</div>
					<div>
						<h3 class="text-xs font-bold uppercase tracking-wide opacity-50 mb-3">Newsletter</h3>
						<form class="flex">
							<input
								type="email"
								placeholder="email"
								required
								class="flex-1 px-4 py-2 text-base bg-transparent border-2 border-black border-r-0 outline-none"
							/>
							<button type="submit" class="px-4 py-2 text-base font-bold border-2 border-black bg-black text-white hover:bg-transparent hover:text-black transition-colors">
								OK
							</button>
						</form>
					</div>
				</div>
			</section>
		</main>
		<Footer />
		<Lightbox />
		<script>
			document.querySelectorAll('.gallery-filter').forEach((btn) => {
				btn.addEventListener('click', () => {
					const filter = (btn as HTMLElement).dataset.filter;
					document.querySelectorAll('.gallery-filter').forEach((b) => {
						b.classList.remove('bg-black', 'text-white');
						b.classList.add('bg-white', 'text-black');
					});
					btn.classList.remove('bg-white', 'text-black');
					btn.classList.add('bg-black', 'text-white');
					document.querySelectorAll<HTMLElement>('[data-year]').forEach((section) => {
						if (filter === 'all' || section.dataset.year === filter) {
							section.classList.remove('hidden');
						} else {
							section.classList.add('hidden');
						}
					});
				});
			});
		</script>
	</body>
</html>
