---
import { Header, Hero, InfoBar, EventCarousel, Footer, Lightbox } from '../components';
import { getEvents } from '../lib/events';
import { getHero } from '../lib/hero';
import '../styles/global.css';

const [hero, events] = await Promise.all([getHero(), getEvents()]);
const years = [...new Set(events.map((e) => e.rawDate.slice(0, 4)))].sort().reverse();
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@400;700&family=Unbounded:wght@400;700&display=swap" rel="stylesheet" />
		<title>Collettivo Sbermuz</title>
	</head>
	<body class="bg-bg">
		<Header />
		<main>
			<Hero title={hero.title} description={hero.description} image={hero.image} date={hero.date} rawDate={hero.rawDate} address={hero.address} price={hero.price} eventSlug={hero.slug} />
			<InfoBar />

			<div id="gallery"></div>
			<h2 class="text-4xl md:text-5xl font-bold font-display text-center pt-16 pb-2">Archivio eventi</h2>
			<nav class="flex flex-wrap gap-3 justify-center px-6 pt-4 pb-4 max-w-6xl mx-auto" aria-label="Filtra per anno">
				<button data-filter="all" class="gallery-filter border-2 border-black px-4 py-1 font-bold font-display shadow-[3px_3px_0_black] bg-black text-white">Tutti</button>
				{years.map((y) => (
					<button data-filter={y} class="gallery-filter border-2 border-black px-4 py-1 font-bold font-display shadow-[3px_3px_0_black] bg-white text-black">{y}</button>
				))}
			</nav>
			{events.map((event) => (
				<EventCarousel title={event.title} date={event.date} rawDate={event.rawDate} flyer={event.flyer} photos={event.photos} year={event.rawDate.slice(0, 4)} />
			))}
		</main>
		<Footer />
		<Lightbox />
		<script>
			document.querySelectorAll('.gallery-filter').forEach((btn) => {
				btn.addEventListener('click', () => {
					const filter = (btn as HTMLElement).dataset.filter;
					document.querySelectorAll('.gallery-filter').forEach((b) => {
						b.classList.remove('bg-black', 'text-white');
						b.classList.add('bg-white', 'text-black');
					});
					btn.classList.remove('bg-white', 'text-black');
					btn.classList.add('bg-black', 'text-white');
					document.querySelectorAll<HTMLElement>('[data-year]').forEach((section) => {
						if (filter === 'all' || section.dataset.year === filter) {
							section.classList.remove('hidden');
						} else {
							section.classList.add('hidden');
						}
					});
				});
			});
		</script>
	</body>
</html>
