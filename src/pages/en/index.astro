---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Header, Hero, InfoBar, EventCarousel, Footer, Lightbox } from '../../components';
import { getEvents } from '../../lib/events';
import { getHero } from '../../lib/hero';
import { t } from '../../lib/i18n';

const locale = 'en' as const;
const [hero, events] = await Promise.all([getHero(), getEvents()]);
const years = [...new Set(events.map((e) => e.rawDate.slice(0, 4)))].sort().reverse();
---

<BaseLayout locale={locale}>
	<Header locale={locale} />
	<main>
		<Hero title={hero.title} description={hero.description} image={hero.image} imageWidth={hero.imageWidth} imageHeight={hero.imageHeight} date={hero.date} dateEn={hero.dateEn} rawDate={hero.rawDate} address={hero.address} price={hero.price} eventSlug={hero.slug} locale={locale} />
		<InfoBar locale={locale} />

		<div id="gallery"></div>
		<h2 class="text-4xl md:text-5xl font-bold font-display text-center pt-16 pb-2">{t('gallery.title', locale)}</h2>
		<nav class="flex flex-wrap gap-3 justify-center px-6 pt-4 pb-4 max-w-6xl mx-auto" aria-label="Filter by year">
			<button data-filter="all" class="gallery-filter border-2 border-black px-4 py-1 font-bold font-display shadow-none translate-x-0.75 translate-y-0.75 hover:shadow-none hover:translate-x-0.75 hover:translate-y-0.75 transition-all bg-black text-white">{t('gallery.all', locale)}</button>
			{years.map((y) => (
				<button data-filter={y} class="gallery-filter border-2 border-black px-4 py-1 font-bold font-display shadow-[3px_3px_0_black] hover:shadow-none hover:translate-x-0.75 hover:translate-y-0.75 transition-all bg-white text-black">{y}</button>
			))}
		</nav>
		{events.map((event) => (
			<EventCarousel title={event.title} date={event.date} dateEn={event.dateEn} rawDate={event.rawDate} flyer={event.flyer} flyerWidth={event.flyerWidth} flyerHeight={event.flyerHeight} photos={event.photos} year={event.rawDate.slice(0, 4)} locale={locale} />
		))}
	</main>
	<Footer locale={locale} />
	<Lightbox />
	<script>
		document.querySelectorAll('.gallery-filter').forEach((btn) => {
			btn.addEventListener('click', () => {
				const filter = (btn as HTMLElement).dataset.filter;
				document.querySelectorAll('.gallery-filter').forEach((b) => {
					b.classList.remove('bg-black', 'text-white', 'shadow-none', 'translate-x-[3px]', 'translate-y-[3px]');
					b.classList.add('bg-white', 'text-black', 'shadow-[3px_3px_0_black]');
				});
				btn.classList.remove('bg-white', 'text-black', 'shadow-[3px_3px_0_black]');
				btn.classList.add('bg-black', 'text-white', 'shadow-none', 'translate-x-[3px]', 'translate-y-[3px]');
				document.querySelectorAll<HTMLElement>('[data-year]').forEach((section) => {
					if (filter === 'all' || section.dataset.year === filter) {
						section.classList.remove('hidden');
					} else {
						section.classList.add('hidden');
					}
				});
			});
		});
	</script>
</BaseLayout>
