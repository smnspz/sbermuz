---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { Header, Footer } from '../../../components';
import { Button } from '../../../components/atoms';
import EventMap from '../../../components/molecules/EventMap.astro';
import { getAllEventSlugs, getEventBySlug, slugify } from '../../../lib/eventDetail';
import { generateIcs } from '../../../lib/calendar';
import { t } from '../../../lib/i18n';
import TableOfContentsRail from '../../../components/islands/TableOfContentsRail';

const locale = 'en' as const;

export async function getStaticPaths() {
  const slugs = await getAllEventSlugs();
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const event = await getEventBySlug(slug!, locale);

if (!event) {
  return Astro.redirect('/en/');
}

const icsContent = generateIcs({ title: event.title, description: '', date: event.rawDate, address: event.address });

const metaDescription = event.description
  ? event.description.replace(/<[^>]+>/g, '').slice(0, 160).trim()
  : undefined;

const tocEntries = [
  ...(event.description ? [{ id: 'ingresso', label: t('event.tocEntry', locale) }] : []),
  ...(event.artists.length > 0
    ? [{
        id: 'lineup',
        label: 'Line up',
        children: event.artists.map((a) => ({ id: slugify(a.name), label: a.name })),
      }]
    : []),
  ...(event.coordinates ? [{ id: 'dove', label: t('event.where', locale) }] : []),
];
---

<BaseLayout locale={locale} title={`${event.title} - Collettivo Sbermuz`} description={metaDescription} image={event.flyer}>
    <Header locale={locale} />
    <main>
      <!-- Banner -->
      <section class="relative w-full h-[60vh] min-h-100 overflow-hidden">
        <img
          src={`${event.flyer}?width=1200&format=webp&withoutEnlargement=true`}
          alt={event.title}
          class="absolute inset-0 w-full h-full object-cover"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-black/50"></div>
        <div class="absolute inset-0 flex flex-col items-center justify-end pb-12 px-6 text-white text-center">
          <h1 class="text-4xl md:text-6xl font-bold font-display mb-4">{event.title}</h1>
          <p class="text-lg opacity-80 mb-4">{event.dateEn}</p>
          <Button id="add-to-calendar" class="text-black" data-ics={icsContent}>
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /><line x1="12" y1="14" x2="12" y2="18" /><line x1="10" y1="16" x2="14" y2="16" />
            </svg>
            {t('event.addCalendar', locale)}
          </Button>
        </div>
      </section>

      <div class="max-w-6xl mx-auto px-6 mt-12 lg:grid lg:grid-cols-[1fr_200px] lg:gap-12">
        <div>
          <!-- Description -->
          {event.description && (
            <section id="ingresso" class="mt-10">
              <div class="text-lg leading-relaxed prose" set:html={event.description} />
            </section>
          )}

          {event.priceFull && (
            <section class="mt-6">
              <h2 class="text-3xl font-bold font-display mb-6">{t('event.tocEntry', locale)}</h2>
              <p class="text-lg opacity-80">{event.priceFull}</p>
            </section>
          )}

          <!-- Artists -->
          {event.artists.length > 0 && (
            <section class="mt-16 mb-20">
              <h2 id="lineup" class="text-3xl font-bold font-display mb-10">Line up</h2>
              <div class="flex flex-col gap-12">
                {event.artists.map((artist) => (
                  <div id={slugify(artist.name)} class="flex flex-col md:flex-row gap-6 items-start">
                    {artist.photo && (
                      <img
                        src={`${artist.photo}?width=400&format=webp&withoutEnlargement=true`}
                        alt={artist.name}
                        class="w-full md:w-48 h-48 object-cover rounded-lg shrink-0"
                        loading="lazy"
                      />
                    )}
                    <div class="flex flex-col gap-3">
                      <h3 class="text-2xl font-bold font-display">{artist.name}</h3>
                      {artist.genres.length > 0 && (
                        <div class="flex flex-wrap gap-2">
                          {artist.genres.map((genre) => (
                            <span class="px-3 py-1 text-xs font-bold uppercase border-2 border-black rounded-full">
                              {genre}
                            </span>
                          ))}
                        </div>
                      )}
                      {artist.description && (
                        <p class="text-base leading-relaxed opacity-80">{artist.description}</p>
                      )}
                      <div class="flex gap-4 mt-1">
                        {artist.spotifyUrl && (
                          <a href={artist.spotifyUrl} target="_blank" rel="noopener noreferrer" class="text-sm hover:underline underline-offset-4">
                            Spotify
                          </a>
                        )}
                        {artist.bandcampUrl && (
                          <a href={artist.bandcampUrl} target="_blank" rel="noopener noreferrer" class="text-sm hover:underline underline-offset-4">
                            Bandcamp
                          </a>
                        )}
                        {artist.instagramUrl && (
                          <a href={artist.instagramUrl} target="_blank" rel="noopener noreferrer" class="text-sm hover:underline underline-offset-4">
                            Instagram
                          </a>
                        )}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Map -->
          {event.coordinates && (
            <section id="dove" class="mt-16 mb-20">
              <h2 class="text-3xl font-bold font-display mb-6">{t('event.where', locale)}</h2>
              <EventMap coordinates={event.coordinates} locale={locale} />
            </section>
          )}
        </div>

        <!-- ToC rail -->
        <aside class="hidden lg:block pt-10">
          <TableOfContentsRail
            client:idle
            title={t('event.tocTitle', locale)}
            ariaLabel="On this page"
            entries={tocEntries}
          />
        </aside>
      </div>
    </main>
    <Footer locale={locale} />
</BaseLayout>

<script>
  const calBtn = document.getElementById('add-to-calendar');
  calBtn?.addEventListener('click', () => {
    const ics = calBtn.dataset.ics;
    if (!ics) return;
    const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'evento.ics';
    a.click();
    URL.revokeObjectURL(url);
  });
</script>


<style>
  html { scroll-behavior: smooth; }
  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
  }
</style>

