---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { Header, Footer } from '../../../components';
import { getAllEventSlugs, getEventBySlug, slugify } from '../../../lib/eventDetail';
import { t } from '../../../lib/i18n';
import TableOfContentsRail from '../../../components/islands/TableOfContentsRail';

const locale = 'en' as const;

export async function getStaticPaths() {
  const slugs = await getAllEventSlugs();
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const event = await getEventBySlug(slug!);

if (!event) {
  return Astro.redirect('/en/');
}

const tocEntries = [
  ...(event.description ? [{ id: 'ingresso', label: t('event.tocEntry', locale) }] : []),
  ...(event.artists.length > 0
    ? [{
        id: 'lineup',
        label: 'Line up',
        children: event.artists.map((a) => ({ id: slugify(a.name), label: a.name })),
      }]
    : []),
  ...(event.coordinates ? [{ id: 'dove', label: t('event.where', locale) }] : []),
];
---

<BaseLayout locale={locale} title={`${event.title} - Collettivo Sbermuz`}>
    <Header locale={locale} />
    <main>
      <!-- Banner -->
      <section class="relative w-full h-[60vh] min-h-100 overflow-hidden">
        <img
          src={event.flyer}
          alt={event.title}
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-black/50"></div>
        <div class="absolute inset-0 flex flex-col items-center justify-end pb-12 px-6 text-white text-center">
          <h1 class="text-4xl md:text-6xl font-bold font-display mb-4">{event.title}</h1>
          <p class="text-lg opacity-80">{event.dateEn}</p>
        </div>
      </section>

      <div class="max-w-6xl mx-auto px-6 mt-12 lg:grid lg:grid-cols-[1fr_200px] lg:gap-12">
        <div>
          <!-- Description -->
          {event.description && (
            <section id="ingresso" class="mt-10">
              <div class="text-lg leading-relaxed prose" set:html={event.description} />
            </section>
          )}

          <!-- Artists -->
          {event.artists.length > 0 && (
            <section class="mt-16 mb-20">
              <h2 id="lineup" class="text-3xl font-bold font-display mb-10">Line up</h2>
              <div class="flex flex-col gap-12">
                {event.artists.map((artist) => (
                  <div id={slugify(artist.name)} class="flex flex-col md:flex-row gap-6 items-start">
                    {artist.photo && (
                      <img
                        src={artist.photo}
                        alt={artist.name}
                        class="w-full md:w-48 h-48 object-cover rounded-lg shrink-0"
                      />
                    )}
                    <div class="flex flex-col gap-3">
                      <h3 class="text-2xl font-bold font-display">{artist.name}</h3>
                      {artist.genres.length > 0 && (
                        <div class="flex flex-wrap gap-2">
                          {artist.genres.map((genre) => (
                            <span class="px-3 py-1 text-xs font-bold uppercase border-2 border-black rounded-full">
                              {genre}
                            </span>
                          ))}
                        </div>
                      )}
                      {artist.description && (
                        <p class="text-base leading-relaxed opacity-80">{artist.description}</p>
                      )}
                      <div class="flex gap-4 mt-1">
                        {artist.spotifyUrl && (
                          <a href={artist.spotifyUrl} target="_blank" rel="noopener noreferrer" class="text-sm hover:underline underline-offset-4">
                            Spotify
                          </a>
                        )}
                        {artist.bandcampUrl && (
                          <a href={artist.bandcampUrl} target="_blank" rel="noopener noreferrer" class="text-sm hover:underline underline-offset-4">
                            Bandcamp
                          </a>
                        )}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Map -->
          {event.coordinates && (
            <section id="dove" class="mt-16 mb-20">
              <h2 class="text-3xl font-bold font-display mb-6">{t('event.where', locale)}</h2>
              <div class="rounded-lg overflow-hidden border-2 border-black shadow-[4px_4px_0_0_black]">
                <iframe
                  title={t('event.mapTitle', locale)}
                  width="100%"
                  height="350"
                  style="border:0"
                  loading="lazy"
                  src={`https://www.openstreetmap.org/export/embed.html?bbox=${event.coordinates[1] - 0.002}%2C${event.coordinates[0] - 0.001}%2C${event.coordinates[1] + 0.002}%2C${event.coordinates[0] + 0.001}&layer=mapnik&marker=${event.coordinates[0]}%2C${event.coordinates[1]}`}
                />
              </div>
            </section>
          )}
        </div>

        <!-- ToC rail -->
        <aside class="hidden lg:block pt-10">
          <TableOfContentsRail
            client:idle
            title={t('event.tocTitle', locale)}
            ariaLabel="On this page"
            entries={tocEntries}
          />
        </aside>
      </div>
    </main>
    <Footer locale={locale} />
</BaseLayout>

<style>
  html { scroll-behavior: smooth; }
  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
  }
</style>

