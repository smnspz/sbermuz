---
import type { Locale } from '../lib/i18n';
import '../styles/global.css';

interface Props {
  locale?: Locale;
  title?: string;
  bodyClass?: string;
}

const { locale = 'it', title = 'Collettivo Sbermuz', bodyClass = 'bg-bg' } = Astro.props;
---

<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@400;700&family=Unbounded:wght@400;700&display=swap" rel="stylesheet" />
		<title>{title}</title>
	</head>
	<body class={bodyClass}>
		<slot />
	</body>
</html>
